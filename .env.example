# ─────────────────────────────────────────────────────────────────────────────
# Mailvex — production deployment configuration
#
#   cp .env.example .env   &&   edit values below   →   ./infra/deploy.sh
#
# This single file drives the entire docker-compose.prod.yml stack.
# DATABASE_URL / REDIS_URL passwords must match POSTGRES_PASSWORD / REDIS_PASSWORD.
# ─────────────────────────────────────────────────────────────────────────────

# ── Domains (create DNS A records pointing at this VPS's public IP) ──────────
APP_DOMAIN=app.mailvex.raghuraj.codes
API_DOMAIN=api.mailvex.raghuraj.codes

# Email used by Let's Encrypt for expiry notices.
ACME_EMAIL=you@example.com

# ── PostgreSQL container (internal only, not exposed to the internet) ───────
POSTGRES_USER=mailvex
POSTGRES_PASSWORD=change-me-to-a-strong-db-password
POSTGRES_DB=mailvex

# ── Redis container (internal only) ─────────────────────────────────────────
REDIS_PASSWORD=change-me-to-a-strong-redis-password

# ─── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
APP_NAME=mailvex-api
APP_VERSION=1.0.0

# ─── HTTP server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=4000
TRUST_PROXY=true
BODY_LIMIT_BYTES=1048576
REQUEST_TIMEOUT_MS=30000

# ─── Public URLs (used in emails) ──────────────────────────────────────────────
APP_PUBLIC_URL=https://app.mailvex.raghuraj.codes
API_PUBLIC_URL=https://api.mailvex.raghuraj.codes

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://app.mailvex.raghuraj.codes

# ─── PostgreSQL (API — host `postgres` on Docker network) ────────────────────
DATABASE_URL=postgres://mailvex:change-me-to-a-strong-db-password@postgres:5432/mailvex
DATABASE_POOL_MAX=20
DATABASE_IDLE_TIMEOUT_S=30
DATABASE_CONNECT_TIMEOUT_S=10
DATABASE_SSL=false

# ─── Redis (API — host `redis` on Docker network) ──────────────────────────────
REDIS_URL=redis://:change-me-to-a-strong-redis-password@redis:6379/0
REDIS_KEY_PREFIX=mailvex:

# ─── NATS ──────────────────────────────────────────────────────────────────────
NATS_URL=nats://nats:4222
NATS_NAME=mailvex-api

# ─── JWT / Auth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-min-32-chars-random-secret-value
JWT_REFRESH_SECRET=change-me-different-min-32-chars-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ISSUER=mailvex
JWT_AUDIENCE=mailvex-api

# ─── Auth security ─────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=10
ACCOUNT_LOCKOUT_WINDOW_S=900
ACCOUNT_LOCKOUT_DURATION_S=900
PASSWORD_RESET_TTL_S=3600
EMAIL_VERIFICATION_TTL_S=86400
INVITE_TTL_S=604800
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW=1m

# ─── Internal / inter-service auth ─────────────────────────────────────────────
INTERNAL_API_KEY=change-me-min-16-chars

# ─── Email (SES) ───────────────────────────────────────────────────────────────
EMAIL_FROM=no-reply@mailvex.raghuraj.codes
EMAIL_REPLY_TO=support@mailvex.raghuraj.codes
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Swagger ───────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=false
SWAGGER_PATH=/docs

# ─── Stripe billing (optional — leave blank to disable billing) ───────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2024-12-18.acacia
STRIPE_CHECKOUT_SUCCESS_URL=https://app.mailvex.raghuraj.codes/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=https://app.mailvex.raghuraj.codes/billing/cancel
STRIPE_PORTAL_RETURN_URL=https://app.mailvex.raghuraj.codes/billing
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_YEARLY_PRICE_ID=
STRIPE_GROWTH_MONTHLY_PRICE_ID=
STRIPE_GROWTH_YEARLY_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_SCALE_MONTHLY_PRICE_ID=
STRIPE_SCALE_YEARLY_PRICE_ID=

# ─── Workers ───────────────────────────────────────────────────────────────────
SES_RATE_LIMIT_PER_SEC=14
CAMPAIGN_CHUNK_SIZE=500
METRICS_PORT=9090
