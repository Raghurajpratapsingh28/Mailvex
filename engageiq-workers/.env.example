# Mailvex Workers — Environment Configuration
# Copy to .env and fill in values before running.

# ── Required ──────────────────────────────────────────────────────────────────
NATS_URL=nats://nats:4222
DATABASE_URL=postgres://Mailvex:secret@postgres:5432/Mailvex?sslmode=disable
REDIS_URL=redis://redis:6379/0
AWS_REGION=us-east-1

# ── AWS Credentials (omit in production — use IAM roles instead) ──────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Optional / Defaults ───────────────────────────────────────────────────────
METRICS_PORT=9090
SES_RATE_LIMIT_PER_SEC=14
CAMPAIGN_CHUNK_SIZE=500
EVENT_MAX_RETRIES=5
EVENT_BATCH_SIZE=100
SEGMENT_MAX_RETRIES=5
WORKFLOW_MAX_RETRIES=5
WORKFLOW_SCHEDULER_POLL_INTERVAL=30s
